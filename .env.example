# =============================================
# UrbanPulse VN — Environment Variables
# =============================================
# Copy this file to .env before running:
#   cp .env.example .env
#
# ⚠️  NEVER commit .env to Git!

# ── PostgreSQL ──
POSTGRES_USER=urbanpulse
POSTGRES_PASSWORD=urbanpulse_dev_2024
POSTGRES_DB=urbanpulse
POSTGRES_PORT=5432

# ── MinIO (S3-compatible Object Storage) ──
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── Redis ──
REDIS_PORT=6379

# ── Trino (Query Engine) ──
TRINO_PORT=8090

# ── Nessie (Iceberg Catalog) ──
NESSIE_PORT=19120

# ── Vault (Secret Management — Dev Mode) ──
VAULT_DEV_ROOT_TOKEN_ID=urbanpulse-dev-token
VAULT_PORT=8200

# ── Kafka (Sprint 2) ──
# KAFKA_PORT=9092
# KAFKA_CONTROL_CENTER_PORT=9021

# ── Airflow (Sprint 3) ──
# AIRFLOW_PORT=8080
# AIRFLOW__CORE__FERNET_KEY=<generate-with-python>

# ── Spark (Sprint 3) ──
# SPARK_MASTER_PORT=7077
# SPARK_UI_PORT=8091

# ── Streamlit (Sprint 4) ──
# STREAMLIT_PORT=8501

# ── JupyterLab (Sprint 4) ──
# JUPYTER_PORT=8888
# JUPYTER_TOKEN=urbanpulse-jupyter

# ── MLflow (Sprint 4) ──
# MLFLOW_PORT=5001
# MLFLOW_S3_ENDPOINT_URL=http://minio:9000

# ── Marquez / Data Lineage (Sprint 3) ──
# MARQUEZ_PORT=5000
# MARQUEZ_WEB_PORT=3001

# ── API Keys (Sprint 1 — Ingestion) ──
# NASA_EARTHDATA_TOKEN=
# OPENAQ_API_KEY=
